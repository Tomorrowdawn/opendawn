#!/usr/bin/env python3
"""purist -- python-purist skill auxiliary CLI.

Usage:
  purist list [best-practice|case-study|cookbook|all]
  purist related <filename.md>
  purist search <keyword>
  purist tags [<filter>]
  purist check <folder>
  purist checklist
  purist help
"""

import os
import re
import subprocess
import sys
from pathlib import Path

SKILL_DIR = Path(__file__).resolve().parent.parent
BP_DIR = SKILL_DIR / "best-practice"
CS_DIR = SKILL_DIR / "case-study"
CK_DIR = SKILL_DIR / "cookbook"


# -- frontmatter parser ----------------------------------------------------

def parse_frontmatter(filepath: Path) -> dict:
    """Extract YAML frontmatter as a dict. Handles scalar and list values."""
    with open(filepath) as f:
        content = f.read()

    m = re.match(r'^---\s*\n(.*?)\n---', content, re.DOTALL)
    if not m:
        return {}

    fm_text = m.group(1)
    result: dict[str, str | list[str]] = {}
    current_key = None
    current_list: list[str] = []

    for line in fm_text.split('\n'):
        m = re.match(r'^(\w[\w-]*):\s*(.*)', line)
        if m:
            if current_key is not None and current_list:
                result[current_key] = current_list
                current_list = []
                current_key = None
            key = m.group(1)
            val = m.group(2).strip()
            if val == '':
                current_key = key
                current_list = []
            elif val.startswith('"') and val.endswith('"'):
                result[key] = val[1:-1]
            elif val.startswith('[') and val.endswith(']'):
                items = val[1:-1].split(',')
                result[key] = [i.strip().strip('"\'') for i in items if i.strip()]
            else:
                result[key] = val
            continue

        m = re.match(r'^\s+-\s+(.*)', line)
        if m and current_key is not None:
            item = m.group(1).strip().strip('"\'')
            current_list.append(item)

    if current_key is not None and current_list:
        result[current_key] = current_list

    return result


# -- ruff integration ------------------------------------------------------

def _find_ruff_cmd() -> list[str] | None:
    """Find a working ruff command: uv run ruff -> python -m ruff -> ruff."""
    candidates: list[list[str]] = [
        ["uv", "run", "ruff"],
        [sys.executable, "-m", "ruff"],
        ["ruff"],
    ]
    for cmd in candidates:
        try:
            subprocess.run(
                [*cmd, "--version"],
                capture_output=True, check=True, timeout=10,
            )
            return cmd
        except (FileNotFoundError, subprocess.CalledProcessError, PermissionError):
            continue
    return None


def _run_ruff_check(target: Path) -> int:
    """Run ruff for C901 (complex-structure) and PLR0915 (too-many-statements).
    Returns the number of issues found, or -1 if ruff is unavailable."""
    ruff_cmd = _find_ruff_cmd()
    if ruff_cmd is None:
        return -1

    try:
        result = subprocess.run(
            [*ruff_cmd, "check", "--select", "C901,PLR0915", str(target)],
            capture_output=True, text=True, timeout=60,
            cwd=target if target.is_dir() else target.parent,
        )
    except (subprocess.TimeoutExpired, OSError):
        return -1

    output = result.stdout.strip()
    if not output:
        return 0

    issue_count = len(output.splitlines())
    print(f"[RUFF] function complexity ({issue_count} issue(s))")
    print(f"       rules: C901 (McCabe), PLR0915 (too-many-statements)")
    for line in output.splitlines():
        print(f"       {line}")
    return issue_count


# -- underscore checks -----------------------------------------------------

def _check_underscore_files(target_path: Path) -> int:
    """Check directories with >=2 underscore-prefixed entries (non-recursive per dir).
    Excludes __init__.py and __pycache__."""
    issues: list[str] = []
    for dirpath_str, dirnames, filenames in os.walk(str(target_path)):
        underscored: list[str] = []
        for name in filenames:
            if name.startswith('_') and name != '__init__.py':
                underscored.append(name)
        for name in dirnames:
            if name.startswith('_') and name != '__pycache__':
                underscored.append(name)
        if len(underscored) >= 2:
            rel = Path(dirpath_str).relative_to(target_path)
            joined = ', '.join(underscored[:5])
            if len(underscored) > 5:
                joined += f' ... +{len(underscored) - 5} more'
            issues.append(f"       {rel}/ -> {len(underscored)} _-prefixed: {joined}")

    if issues:
        count = len(issues)
        plural = "es" if count > 1 else ""
        print(f"  [WARNING] underscore-dir ({count} director{plural} with >=2 _-prefixed entries)")
        for issue in issues[:10]:
            print(issue)
        if len(issues) > 10:
            print(f"       ... and {len(issues) - 10} more")
        return len(issues)
    return 0


def _check_underscore_init(target_path: Path) -> int:
    """Check __init__ blocks with >=3 self._xxx = ... assignments."""
    issues: list[str] = []
    for pyfile in sorted(target_path.rglob("*.py")):
        try:
            with open(pyfile) as f:
                lines = f.readlines()
        except (OSError, UnicodeDecodeError):
            continue

        i = 0
        while i < len(lines):
            m = re.match(r'^(\s*)def\s+__init__\s*\(', lines[i])
            if not m:
                i += 1
                continue

            base_indent = len(m.group(1))
            init_line = i + 1
            count = 0
            i += 1
            while i < len(lines):
                line = lines[i]
                # End: new def/class at same or less indent
                end_m = re.match(r'^(\s*)(def\s+|class\s+)', line)
                if end_m and len(end_m.group(1)) <= base_indent:
                    break
                # Skip docstrings and comments
                stripped = line.strip()
                if stripped.startswith('#') or stripped.startswith('"""') or stripped.startswith("'''"):
                    i += 1
                    continue
                if re.search(r'self\._\w+\s*=', line):
                    count += 1
                i += 1

            if count >= 3:
                # Find class name by scanning backwards
                class_name = None
                for j in range(init_line - 2, -1, -1):
                    cm = re.match(r'^(\s*)class\s+(\w+)', lines[j])
                    if cm and len(cm.group(1)) < base_indent:
                        class_name = cm.group(2)
                        break
                label = f"{class_name}.__init__" if class_name else "__init__"
                issues.append(f"       {pyfile}:{init_line}: {label} has {count} self._xxx assignments")

    if issues:
        count = len(issues)
        plural = "es" if count > 1 else ""
        print(f"  [WARNING] underscore-init ({count} class{plural} with >=3 self._xxx in __init__)")
        for issue in issues[:10]:
            print(issue)
        if len(issues) > 10:
            print(f"       ... and {len(issues) - 10} more")
        return len(issues)
    return 0


def _check_underscore_class_attrs(target_path: Path) -> int:
    """Check class bodies with >=3 _xxx: type annotations (before first def)."""
    issues: list[str] = []
    for pyfile in sorted(target_path.rglob("*.py")):
        try:
            with open(pyfile) as f:
                lines = f.readlines()
        except (OSError, UnicodeDecodeError):
            continue

        i = 0
        while i < len(lines):
            m = re.match(r'^(\s*)class\s+(\w+)', lines[i])
            if not m:
                i += 1
                continue

            base_indent = len(m.group(1))
            class_name = m.group(2)
            class_line = i + 1
            count = 0
            i += 1
            while i < len(lines):
                line = lines[i]
                # End: def/class at same or shallower indent
                end_m = re.match(r'^(\s*)(def\s+|class\s+)', line)
                if end_m:
                    next_indent = len(end_m.group(1))
                    if next_indent <= base_indent:
                        break  # Same level or outer scope
                    if next_indent > base_indent:
                        break  # First def/class inside — end of class body annotations
                # Count _xxx: type annotations (not def _xxx)
                if re.search(r'^\s+_\w+\s*:', line):
                    count += 1
                i += 1

            if count >= 3:
                issues.append(f"       {pyfile}:{class_line}: class '{class_name}' has {count} _xxx: type annotations")

    if issues:
        count = len(issues)
        plural = "es" if count > 1 else ""
        print(f"  [WARNING] underscore-class-attr ({count} class{plural} with >=3 _xxx: type annotations)")
        for issue in issues[:10]:
            print(issue)
        if len(issues) > 10:
            print(f"       ... and {len(issues) - 10} more")
        return len(issues)
    return 0


# -- commands --------------------------------------------------------------

def cmd_list(category: str = "all") -> None:
    dirs: list[tuple[str, Path]] = []
    if category in ("best-practice", "all"):
        dirs.append(("best-practice", BP_DIR))
    if category in ("case-study", "all"):
        dirs.append(("case-study", CS_DIR))
    if category in ("cookbook", "all"):
        dirs.append(("cookbook", CK_DIR))

    for cat_name, dir_path in dirs:
        print(f"\n# {cat_name}\n")
        for fpath in sorted(dir_path.glob("*.md")):
            fm = parse_frontmatter(fpath)
            title = fm.get("title", "")
            summary = fm.get("summary", "")
            tags = fm.get("tags", [])

            parts = [fpath.name]
            if title:
                parts.append(title)
            if summary:
                parts.append(f"({summary})")
            if tags:
                tag_str = ", ".join(tags if isinstance(tags, list) else [tags])
                parts.append(f"[{tag_str}]")
            print("  " + " -- ".join(parts))


def cmd_related(target: str) -> None:
    fullpath = None
    for d in (BP_DIR, CS_DIR, CK_DIR):
        cand = d / target
        if cand.exists():
            fullpath = cand
            break

    if fullpath is None:
        print(f"Error: '{target}' not found in best-practice/, case-study/, or cookbook/", file=sys.stderr)
        sys.exit(1)

    fm = parse_frontmatter(fullpath)
    title = fm.get("title", "")
    related = fm.get("related", [])

    print(f"Related to: {fullpath.name} -- {title}")
    if not related:
        print("  (no related docs listed)")
        return

    for rel in related:
        rel = str(rel)
        if rel.startswith("../"):
            rel_path = SKILL_DIR / rel[3:]
        else:
            rel_path = fullpath.parent / rel

        if rel_path.exists():
            rel_fm = parse_frontmatter(rel_path)
            rel_title = rel_fm.get("title", "")
            print(f"  {rel:<40s}  {rel_title}")
        else:
            print(f"  {rel:<40s}  [missing]")


def cmd_search(keyword: str) -> None:
    """Search case studies and best-practice docs by keyword."""
    keyword_lower = keyword.lower()
    results: list[tuple[int, Path, str, str]] = []

    for cat_name, dir_path in [("best-practice", BP_DIR), ("case-study", CS_DIR), ("cookbook", CK_DIR)]:
        for fpath in sorted(dir_path.glob("*.md")):
            fm = parse_frontmatter(fpath)
            score = 0
            reasons: list[str] = []

            if keyword_lower in fpath.name.lower():
                score += 10
                reasons.append("filename")

            title = str(fm.get("title", ""))
            if keyword_lower in title.lower():
                score += 8
                reasons.append("title")

            tags = fm.get("tags", [])
            if isinstance(tags, list):
                matched_tags = [t for t in tags if keyword_lower in str(t).lower()]
                if matched_tags:
                    score += 5 * len(matched_tags)
                    reasons.append(f"tags: {', '.join(matched_tags)}")
            elif isinstance(tags, str) and keyword_lower in tags.lower():
                score += 5
                reasons.append(f"tag: {tags}")

            summary = str(fm.get("summary", ""))
            if keyword_lower in summary.lower():
                score += 3
                reasons.append("summary")

            if score > 0:
                results.append((score, fpath, cat_name, ", ".join(reasons)))

    results.sort(key=lambda x: x[0], reverse=True)

    if not results:
        print(f"No results for '{keyword}'. Try broader terms or `purist list` to browse all docs.")
        return

    print(f"\nSearch results for: '{keyword}'")
    for score, fpath, cat_name, reason in results[:15]:
        fm = parse_frontmatter(fpath)
        title = fm.get("title", "")
        print(f"  [{cat_name}] {fpath.name} (score: {score})")
        if title:
            print(f"           {title}")
        print(f"           matched: {reason}")

    if len(results) > 15:
        print(f"  ... and {len(results) - 15} more. Narrow your search.")


def cmd_check(target: str) -> None:
    target_path = Path(target).resolve()
    if not target_path.is_dir():
        print(f"Error: '{target}' is not a directory", file=sys.stderr)
        sys.exit(1)

    patterns = [
        ("ERROR",   "bare-except",           r"except\s*:\s*$"),
        ("ERROR",   "type-ignore",           r"#\s*type:\s*ignore"),
        ("ERROR",   "print-as-log",          r"^\s*print\("),
        ("ERROR",   "loguru-import",         r"from loguru import|import loguru"),
        ("WARNING", "dict-str-any",          r"dict\[str,\s*Any\]"),
        ("WARNING", "noqa",                  r"#\s*noqa"),
        ("WARNING", "bare-object-annotation", r":[^=]*\bobject\b"),
        ("WARNING", "kwargs-passthrough",    r"\*\*kwargs"),
        ("WARNING", "data-passthrough",      r"\*\*data"),
        ("WARNING", "deep-inheritance",      r"class\s+\w+\([^)]*,[^)]*,[^)]*\)"),
        ("WARNING", "logging-file-handler",  r"FileHandler|TimedRotatingFileHandler|RotatingFileHandler|logger\.add\(.*\.log"),
        ("REVIEW",  "magic-getattr",         r"__getattr__"),
        ("REVIEW",  "magic-setattr",         r"__setattr__"),
        ("REVIEW",  "magic-delattr",         r"__delattr__"),
        ("REVIEW",  "hasattr-abuse",         r"hasattr\s*\("),
        ("REVIEW",  "bare-any-annotation",   r":[^=]*\bAny\b"),
        ("REVIEW",  "bare-exception-catch",  r"except\s+Exception"),
        ("REVIEW",  "abc-inheritance",       r"class\s+\w+\([^)]*ABC[^)]*\)"),
        ("REVIEW",  "two-phase-init",        r"def\s+(setup|init|connect|initialize)\s*\(self"),
        ("ERROR",   "typeguard-validation",   r"TypeGuard"),
        ("WARNING", "recursive-type-alias",   r"^type\s+\w+\s*=.*\|.*list\["),
    ]

    print(f"\nPurist Check: {target_path}")
    found_any = False

    # -- line count checks -------------------------------------------------
    oversized: list[tuple[Path, int, str]] = []
    for pyfile in sorted(target_path.rglob("*.py")):
        try:
            with open(pyfile) as f:
                line_count = sum(1 for _ in f)
        except (OSError, UnicodeDecodeError):
            continue

        if line_count > 600:
            severity = "ERROR"
        elif line_count > 400:
            severity = "WARNING"
        else:
            continue
        oversized.append((pyfile, line_count, severity))

    if oversized:
        found_any = True
        for pyfile, count, sev in oversized:
            print(f"  [{sev}] too-many-lines ({count} lines) -> {pyfile}")

    # -- pattern checks ----------------------------------------------------
    for severity, label, pattern in patterns:
        matches = []
        for pyfile in target_path.rglob("*.py"):
            try:
                with open(pyfile) as f:
                    for lineno, line in enumerate(f, 1):
                        if re.search(pattern, line):
                            matches.append(f"       {pyfile}:{lineno}: {line.rstrip()}")
            except (OSError, UnicodeDecodeError):
                continue

        if matches:
            found_any = True
            plural = "es" if len(matches) > 1 else ""
            print(f"  [{severity}] {label} ({len(matches)} match{plural})")
            for m in matches[:10]:
                print(m)
            if len(matches) > 10:
                print(f"       ... and {len(matches) - 10} more")

    # -- underscore checks --------------------------------------------------
    u_files = _check_underscore_files(target_path)
    if u_files > 0:
        found_any = True
    u_init = _check_underscore_init(target_path)
    if u_init > 0:
        found_any = True
    u_attrs = _check_underscore_class_attrs(target_path)
    if u_attrs > 0:
        found_any = True

    # -- ruff: function complexity -----------------------------------------
    ruff_issues = _run_ruff_check(target_path)
    if ruff_issues > 0:
        found_any = True
    elif ruff_issues == -1:
        print(f"[RUFF] ruff not available. Install: uv add --dev ruff, or pip install ruff")
        print("       Function complexity checks skipped (C901 + PLR0915).")

    if not found_any:
        print("  No purist violations detected.")


def cmd_checklist() -> None:
    print("""Quality Checklist

  Type safety:
  - [ ] All function params and returns fully type-annotated? Zero Any, type: ignore, # noqa?
  - [ ] Serialization boundaries have explicit schema (msgspec.Struct)? Data validated once at boundary, never patched downstream?

  Directness:
  - [ ] Zero hasattr() or dict.get(key, default) masking missing data? Zero input patching chains?
  - [ ] Zero except: pass or bare except? Errors propagate to the layer that can actually handle them?

  Architecture:
  - [ ] Core logic functions free of I/O? External resources have a single lifecycle owner?
  - [ ] Every public function has a test? Test written before implementation?

  Observability:
  - [ ] All logging structured (structlog)? Zero print() or loguru? Output to stderr only? Telemetry fault-isolated?

  Complexity:
  - [ ] Files <= 400 lines (warning) / <= 600 lines (error)? Functions pass `purist check` complexity checks?
""")


def cmd_tags(filter_str: str | None = None) -> None:
    """List all tags used across the skill with file counts."""
    tag_counts: dict[str, int] = {}
    for dir_path in (BP_DIR, CS_DIR, CK_DIR):
        for fpath in dir_path.glob("*.md"):
            fm = parse_frontmatter(fpath)
            tags = fm.get("tags", [])
            if isinstance(tags, list):
                for tag in tags:
                    tag_counts[tag] = tag_counts.get(tag, 0) + 1
            elif isinstance(tags, str):
                tag_counts[tags] = tag_counts.get(tags, 0) + 1

    sorted_tags = sorted(tag_counts.items(), key=lambda x: x[0])

    if filter_str:
        filter_lower = filter_str.lower()
        sorted_tags = [(t, c) for t, c in sorted_tags if filter_lower in t.lower()]

    if not sorted_tags:
        msg = f"  No tags matching '{filter_str}'." if filter_str else "  (no tags found)"
        print(f"\n{msg}")
        return

    total = len(sorted_tags)
    print(f"\nAvailable tags ({total} total)")
    col_width = max(len(t) for t, _ in sorted_tags) + 2
    for tag, count in sorted_tags:
        print(f"  {tag:<{col_width}}  {count} file{'s' if count != 1 else ' '}")

    print(f"\n  Use: purist search <tag> to find docs by tag")


def cmd_help() -> None:
    print("""Usage: purist {list|related|search|tags|check|checklist} [args...]

Commands:
  list [best-practice|case-study|cookbook|all]  List docs with title, tags, summary
  related <filename.md>               Show related docs from frontmatter
  search <keyword>                     Search docs by keyword (titles, tags, summaries)
  tags [<filter>]                      List all tags with file counts (optional substring filter)
  check <folder>                      Scan Python code for anti-patterns
  checklist                           Print the quality checklist
""")


# -- main -------------------------------------------------------------------

def main() -> None:
    if len(sys.argv) < 2:
        cmd_help()
        sys.exit(1)

    cmd = sys.argv[1]
    args = sys.argv[2:]

    commands = {
        "list":      lambda: cmd_list(args[0] if args else "all"),
        "related":   lambda: cmd_related(args[0] if args else ""),
        "search":    lambda: cmd_search(args[0] if args else ""),
        "tags":      lambda: cmd_tags(args[0] if args else None),
        "check":     lambda: cmd_check(args[0] if args else "."),
        "checklist": cmd_checklist,
        "help":      cmd_help,
        "--help":    cmd_help,
        "-h":        cmd_help,
    }

    if cmd in commands:
        commands[cmd]()
    else:
        print(f"Unknown command: {cmd}", file=sys.stderr)
        cmd_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
